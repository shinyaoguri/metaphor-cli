# metaphor-cli: ローカル開発ビルドを PATH 前方に差し込む。
#
# このディレクトリ(とサブディレクトリ)にいる間だけ、ここのビルド成果物が
# brew 版 (/opt/homebrew/bin/metaphor) より優先される。外に出れば自動で
# brew 版に戻る。手動の install/uninstall トグルは不要。
#
# 成果物は Syphon.framework が隣接し @loader_path で解決されるため、
# `make install` のような rpath 付与・再署名なしでビューアも動く。
#
# 既定は debug ビルド。`swift build` で更新され即反映される。
# release を使いたいときは:  METAPHOR_BUILD=release direnv allow
#   (事前に `swift build -c release` を実行)
BUILD="${METAPHOR_BUILD:-debug}"

if [ -x ".build/${BUILD}/metaphor" ]; then
  PATH_add ".build/${BUILD}"
else
  log_status "metaphor: .build/${BUILD}/metaphor が未ビルド。'swift build' 後に 'direnv reload' で開発版を有効化 (今は brew 版を使用)"
fi
